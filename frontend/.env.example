# VoiceTrace Frontend Configuration

# Backend API
VITE_API_BASE_URL=http://localhost:8000/api

# Feature Flags
VITE_ENABLE_AUDIO_PLAYBACK=true
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_EXPORT_PDF=true

# Configuration
VITE_MAX_RECORDING_DURATION=180
VITE_ITEMS_PER_PAGE=30

# Feature: WhatsApp Integration
VITE_WHATSAPP_ENABLED=false
VITE_WHATSAPP_PHONE_NUMBER=

# Feature: Advanced Analytics
VITE_ENABLE_DEMAND_PREDICTION=false
VITE_ENABLE_ANOMALY_DETECTION=false
VITE_ENABLE_STOCK_SUGGESTIONS=true
